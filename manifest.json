{
  "manifest_version": 2,
  "name": "Simple Password Generator",
  "version": "1.0",
  "description": "A simple secure password generator.",
  "permissions": ["storage"],
  "browser_action": {
    "default_icon": "padlock128x128.png",
    "default_popup": "password.html"
  },
  "content_security_policy": "script-src 'self' https://fonts.googleapis.com/css 'unsafe-eval'; object-src 'self'"
}
